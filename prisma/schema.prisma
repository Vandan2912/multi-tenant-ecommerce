generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Tenants ────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String   @unique
  slug      String   @unique
  plan      String   @default("basic")
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeConfig StoreConfig?
  products    Product[]
  categories  Category[]
  brands      Brand[]
  orders      Order[]
  customers   Customer[]
  adminUsers  AdminUser[]
  optionTypes OptionType[]
  promoCodes  PromoCode[]
}

// ── Store Config ───────────────────────────────────────────
model StoreConfig {
  id                 String  @id @default(uuid())
  tenant_id          String  @unique
  primary_color      String? @default("#2563EB")
  font_family        String? @default("Inter")
  hero_layout        String? @default("centered")
  product_card_style String? @default("minimal")
  logo_url           String?
  store_tagline      String?
  features_json      Json?
  contact_json       Json?
  seo_json           Json?
  razorpay_key_id    String?
  shipping_json      Json?

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

// ── Brands ─────────────────────────────────────────────────
model Brand {
  id        String   @id @default(uuid())
  tenant_id String
  name      String
  slug      String
  logo_url  String?
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenant_id, slug])
  @@index([tenant_id])
}

// ── Categories (self-relation for subcategories) ───────────
model Category {
  id        String   @id @default(uuid())
  tenant_id String
  name      String
  slug      String
  parent_id String?
  createdAt DateTime @default(now())

  tenant   Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryChildren", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@index([tenant_id, parent_id])
}

// ── Products ───────────────────────────────────────────────
model Product {
  id          String   @id @default(uuid())
  tenant_id   String
  category_id String?
  brand_id    String?
  name        String
  description String?
  images      String[]
  specs_json  Json?
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [category_id], references: [id])
  brand          Brand?          @relation(fields: [brand_id], references: [id])
  variants       Variant[]
  productOptions ProductOption[]

  @@index([tenant_id])
  @@index([tenant_id, is_active])
  @@index([tenant_id, category_id])
  @@index([tenant_id, brand_id])
}

// ── Variants ───────────────────────────────────────────────
model Variant {
  id             String   @id @default(uuid())
  tenant_id      String
  product_id     String
  name           String
  sku            String?
  price          Decimal  @db.Decimal(10, 2)
  discount_price Decimal? @db.Decimal(10, 2)
  stock          Int      @default(0)
  unit           String?
  options_json   Json     @default("{}")
  is_active      Boolean  @default(true)
  createdAt      DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, product_id, name])
  @@index([tenant_id])
  @@index([product_id])
}

// ── Option Types (tenant-level reusable definitions) ───────
model OptionType {
  id           String   @id @default(uuid())
  tenant_id    String
  name         String
  type         String   // TEXT | COLOUR | SIZE | NUMBER | BOOLEAN
  values_json  Json     // array of { id, label, hex?, order? }
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  productOptions ProductOption[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
}

// ── Product Options (which option types a product uses) ────
model ProductOption {
  id                   String   @id @default(uuid())
  product_id           String
  tenant_id            String
  option_type_id       String
  position             Int      @default(0)
  selected_values_json Json     // array of value IDs selected for this product

  product    Product    @relation(fields: [product_id], references: [id], onDelete: Cascade)
  optionType OptionType @relation(fields: [option_type_id], references: [id], onDelete: Cascade)

  @@unique([product_id, option_type_id])
  @@index([product_id])
  @@index([tenant_id])
}

// ── Orders ─────────────────────────────────────────────────
model Order {
  id             String   @id @default(uuid())
  tenant_id      String
  customer_id    String?
  status         String   @default("pending")
  total          Decimal  @db.Decimal(10, 2)
  payment_status String   @default("pending")
  items_json     Json
  address_json   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, status])
}

// ── Customers ──────────────────────────────────────────────
model Customer {
  id        String   @id @default(uuid())
  tenant_id String
  name      String
  email     String?
  phone     String?
  address   Json?
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([tenant_id, email])
  @@index([tenant_id])
}

// ── Admin Users ────────────────────────────────────────────
model AdminUser {
  id            String   @id @default(uuid())
  tenant_id     String
  email         String
  password_hash String
  role          String   @default("admin")
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, email])
  @@index([tenant_id])
}

// ── Promo Codes ────────────────────────────────────────────
model PromoCode {
  id                   String    @id @default(uuid())
  tenant_id            String
  code                 String    // stored uppercase, trimmed
  description          String?
  discount_type        String    // percentage | fixed | free_shipping
  discount_value       Decimal   @db.Decimal(10, 2)
  minimum_order_value  Decimal?  @db.Decimal(10, 2)
  maximum_discount     Decimal?  @db.Decimal(10, 2)  // cap for percentage
  usage_limit          Int?      // global limit
  usage_limit_per_user Int?      // per phone/email
  used_count           Int       @default(0)
  start_date           DateTime?
  expiry_date          DateTime?
  is_active            Boolean   @default(true)
  applicable_products  String[]  // product IDs (empty = all)
  applicable_categories String[] // category IDs (empty = all)
  excluded_products    String[]  // product IDs to exclude
  stackable            Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  usages PromoUsage[]

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([tenant_id, is_active])
}

// ── Promo Usage tracking (per user) ───────────────────────
model PromoUsage {
  id             String   @id @default(uuid())
  promo_code_id  String
  tenant_id      String
  identifier     String   // phone or email
  order_id       String?
  discount_given Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  promoCode PromoCode @relation(fields: [promo_code_id], references: [id], onDelete: Cascade)

  @@index([promo_code_id])
  @@index([tenant_id, identifier])
}